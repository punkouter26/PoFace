@using PoFace.Client.Services
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@* Shown during Analyzing: frozen capture + spinner.
   Shown during ScoreReveal: frozen capture + animated score. *@

@if (State is GameState.Analyzing or GameState.ScoreReveal)
{
    <div class="overlay frozen-frame-overlay" aria-live="polite" aria-atomic="true">
        @* Frozen frame from last capture (imageUrl empty → placeholder) *@
        @if (!string.IsNullOrWhiteSpace(LastResult?.ImageUrl))
        {
            <img src="@LastResult.ImageUrl"
                 alt="Captured frame for round @LastResult.RoundNumber"
                 class="frozen-frame-img" />
        }
        else
        {
            <div class="frozen-frame-placeholder" aria-hidden="true"></div>
        }

        @if (State == GameState.Analyzing)
        {
            <div class="analyzing-spinner" aria-label="Analyzing…">
                <span class="spinner-ring" aria-hidden="true"></span>
                <p>ANALYZING…</p>
            </div>
        }

        @if (State == GameState.ScoreReveal && LastResult is not null)
        {
            <div class="score-reveal-panel" role="status">
                <p class="emotion-label">@LastResult.TargetEmotion</p>
                <p class="score-value" aria-label="Score @_displayScore out of 10">
                    @_displayScore <span class="score-denom">/ 10</span>
                </p>

                @* ── Face API diagnostics (diagnostic mode only) ── *@
                @if (DiagMode)
                {
                    <div class="face-debug-grid">
                        <span class="dbg-label">Face detected</span>
                        <span class="dbg-value @(LastResult.FaceDetected ? "dbg-ok" : "dbg-warn")">
                            @(LastResult.FaceDetected ? "YES" : "NO")
                        </span>

                        <span class="dbg-label">Confidence</span>
                        <span class="dbg-value">@((LastResult.RawConfidence * 100).ToString("0"))%</span>

                        @if (LastResult.FaceDetected)
                        {
                            <span class="dbg-label">Detection</span>
                            <span class="dbg-value">@((LastResult.DetectionConfidence * 100).ToString("0"))%</span>

                            <span class="dbg-label">Landmark</span>
                            <span class="dbg-value">@((LastResult.LandmarkingConfidence * 100).ToString("0"))%</span>

                            <span class="dbg-label">Pose valid</span>
                            <span class="dbg-value @(LastResult.HeadPoseValid ? "dbg-ok" : "dbg-warn")">
                                @(LastResult.HeadPoseValid ? "YES" : "NO")
                            </span>

                            @if (LastResult.HeadPoseYaw.HasValue)
                            {
                                <span class="dbg-label">Yaw</span>
                                <span class="dbg-value">@(LastResult.HeadPoseYaw.Value.ToString("0.0"))°</span>
                            }
                            @if (LastResult.HeadPosePitch.HasValue)
                            {
                                <span class="dbg-label">Pitch</span>
                                <span class="dbg-value">@(LastResult.HeadPosePitch.Value.ToString("0.0"))°</span>
                            }
                            @if (LastResult.HeadPoseRoll.HasValue)
                            {
                                <span class="dbg-label">Roll</span>
                                <span class="dbg-value">@(LastResult.HeadPoseRoll.Value.ToString("0.0"))°</span>
                            }

                            <span class="dbg-label">Quality</span>
                            <span class="dbg-value">@LastResult.QualityLabel</span>

                            <span class="dbg-label">Joy</span>
                            <span class="dbg-value @(LastResult.JoyLikelihood is "High" or "Medium" ? "dbg-ok" : "")">@LastResult.JoyLikelihood</span>

                            <span class="dbg-label">Sorrow</span>
                            <span class="dbg-value @(LastResult.SorrowLikelihood is "High" or "Medium" ? "dbg-warn" : "")">@LastResult.SorrowLikelihood</span>

                            <span class="dbg-label">Anger</span>
                            <span class="dbg-value @(LastResult.AngerLikelihood is "High" or "Medium" ? "dbg-warn" : "")">@LastResult.AngerLikelihood</span>

                            <span class="dbg-label">Surprise</span>
                            <span class="dbg-value @(LastResult.SurpriseLikelihood is "High" or "Medium" ? "dbg-ok" : "")">@LastResult.SurpriseLikelihood</span>

                            @if (LastResult.HeadwearLikelihood is "High" or "Medium" or "Low")
                            {
                                <span class="dbg-label">Headwear</span>
                                <span class="dbg-value dbg-warn">@LastResult.HeadwearLikelihood</span>
                            }
                            @if (!string.IsNullOrEmpty(LastResult.BlurLevel) && LastResult.BlurLevel != "None")
                            {
                                <span class="dbg-label">Blur</span>
                                <span class="dbg-value @(LastResult.BlurLevel == "High" ? "dbg-warn" : "")">@LastResult.BlurLevel</span>
                            }
                            @if (!string.IsNullOrEmpty(LastResult.ExposureLevel))
                            {
                                <span class="dbg-label">Exposure</span>
                                <span class="dbg-value @(LastResult.ExposureLevel == "GoodExposure" ? "dbg-ok" : "dbg-warn")">@LastResult.ExposureLevel</span>
                            }
                        }
                    </div>

                    @if (!LastResult.FaceDetected)
                    {
                        <p class="face-hint">No face detected — check lighting &amp; camera</p>
                    }
                    else if (!LastResult.HeadPoseValid)
                    {
                        <p class="face-hint">Head angle too large — keep head centered</p>
                    }
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public GameState   State      { get; set; }
    [Parameter]                 public RoundResult? LastResult { get; set; }

    private bool DiagMode => Config.GetValue<bool>("DiagnosticMode");

    // Count-up animation: increments toward the real score over 500 ms.
    private int _displayScore;
    private System.Threading.Timer? _countUpTimer;

    protected override async Task OnParametersSetAsync()
    {
        if (State == GameState.ScoreReveal && LastResult is not null)
        {
            _displayScore = 0;
            var target    = LastResult.Score;
            var steps     = target > 0 ? target : 0;
            var interval  = steps > 0 ? 500 / steps : 500;

            _countUpTimer?.Dispose();
            _countUpTimer = new System.Threading.Timer(_ =>
            {
                if (_displayScore < target)
                {
                    _displayScore++;
                    InvokeAsync(StateHasChanged);
                }
                else
                {
                    _countUpTimer?.Dispose();
                }
            }, null, interval, interval);
        }
        else
        {
            _countUpTimer?.Dispose();
        }

        await Task.CompletedTask;
    }

    public void Dispose()
    {
        _countUpTimer?.Dispose();
    }
}

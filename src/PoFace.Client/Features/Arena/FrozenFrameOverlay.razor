@using PoFace.Client.Services
@implements IDisposable

@* Shown during Analyzing: frozen capture + spinner.
   Shown during ScoreReveal: frozen capture + animated score. *@

@if (State is GameState.Analyzing or GameState.ScoreReveal)
{
    <div class="overlay frozen-frame-overlay" aria-live="polite" aria-atomic="true">
        @* Frozen frame from last capture (imageUrl empty → placeholder) *@
        @if (!string.IsNullOrWhiteSpace(LastResult?.ImageUrl))
        {
            <img src="@LastResult.ImageUrl"
                 alt="Captured frame for round @LastResult.RoundNumber"
                 class="frozen-frame-img" />
        }
        else
        {
            <div class="frozen-frame-placeholder" aria-hidden="true"></div>
        }

        @if (State == GameState.Analyzing)
        {
            <div class="analyzing-spinner" aria-label="Analyzing…">
                <span class="spinner-ring" aria-hidden="true"></span>
                <p>ANALYZING…</p>
            </div>
        }

        @if (State == GameState.ScoreReveal && LastResult is not null)
        {
            <div class="score-reveal-panel" role="status">
                <p class="emotion-label">@WithEmoji(LastResult.TargetEmotion)</p>
                <p class="score-value @(LastResult.Score == 10 ? "score-perfect" : "")" aria-label="Score @_displayScore out of 10">
                    @_displayScore <span class="score-denom">/ 10</span>
                </p>

                @if (LastResult.IsNetworkError)
                {
                    <p class="network-error-notice" role="alert">Connection error — this round scored 0</p>
                }

                @* ── Face API diagnostics (diagnostic mode only) ── *@
                @if (DiagMode)
                {
                    <FaceDebugGrid Result="LastResult" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public GameState   State      { get; set; }
    [Parameter]                 public RoundResult? LastResult { get; set; }
    [Parameter]                 public bool         DiagMode   { get; set; }

    private static readonly Dictionary<string, string> _emotionEmoji = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Happy"]     = "\U0001F60A",
        ["Sad"]       = "\U0001F622",
        ["Angry"]     = "\U0001F624",
        ["Surprised"] = "\U0001F632",
        ["Fearful"]   = "\U0001F628",
        ["Disgusted"] = "\U0001F922",
        ["Neutral"]   = "\U0001F610",
    };

    private static string WithEmoji(string? emotion)
    {
        if (emotion is null) return string.Empty;
        return _emotionEmoji.TryGetValue(emotion, out var e) ? $"{e} {emotion}" : emotion;
    }

    // Count-up animation: increments toward the real score over 500 ms.
    private int _displayScore;
    private CancellationTokenSource? _countUpCts;

    protected override async Task OnParametersSetAsync()
    {
        _countUpCts?.Cancel();
        _countUpCts?.Dispose();
        _countUpCts = null;

        if (State == GameState.ScoreReveal && LastResult is not null)
        {
            _displayScore = 0;
            var target = LastResult.Score;
            if (target > 0)
            {
                var interval = TimeSpan.FromMilliseconds(500 / target);
                _countUpCts  = new CancellationTokenSource();
                var cts      = _countUpCts;
                _ = Task.Run(async () =>
                {
                    using var timer = new PeriodicTimer(interval);
                    try
                    {
                        while (_displayScore < target && await timer.WaitForNextTickAsync(cts.Token))
                        {
                            _displayScore++;
                            await InvokeAsync(StateHasChanged);
                        }
                    }
                    catch (OperationCanceledException) { /* component disposed or state changed */ }
                }, CancellationToken.None);
            }
        }

        await Task.CompletedTask;
    }

    public void Dispose()
    {
        _countUpCts?.Cancel();
        _countUpCts?.Dispose();
    }
}

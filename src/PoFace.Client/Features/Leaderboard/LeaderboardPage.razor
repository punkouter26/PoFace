@page "/leaderboard"
@using System.Text.Json
@using PoFace.Client.Services
@inject ApiClient Api

<PageTitle>Leaderboard – PoFace</PageTitle>

<div class="leaderboard-container">

<h1>Leaderboard</h1>

@if (_loading)
{
    <TerminalSpinner Message="FETCHING SCORES..." />
}
else if (_errorMessage is not null)
{
    <p class="text-danger">@_errorMessage</p>
}
else
{
    <p class="leaderboard-meta">Year: <strong>@_year</strong> &mdash; @_entries.Count entries</p>

    <RadzenDataGrid Data="@_entries" TItem="LeaderboardEntryDto" AllowSorting="true" class="leaderboard-grid">
        <Columns>
            <RadzenDataGridColumn TItem="LeaderboardEntryDto" Property="Rank" Title="#" Width="60px">
                <Template Context="entry">
                    <span class="@GetRankClass(entry.Rank)">@entry.Rank</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="LeaderboardEntryDto" Property="DisplayName" Title="Player">
                <Template Context="entry">
                    <span class="@GetRankClass(entry.Rank)">@entry.DisplayName</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="LeaderboardEntryDto" Property="TotalScore" Title="Score" Width="90px">
                <Template Context="entry">
                    <strong class="@GetRankClass(entry.Rank)">@entry.TotalScore</strong>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="LeaderboardEntryDto" Property="DeviceType" Title="Device" Width="100px">
                <Template Context="entry">
                    @(entry.DeviceType == "Mobile" ? "📱" : "🖥️") @entry.DeviceType
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="LeaderboardEntryDto" Title="Gallery" Width="120px">
                <Template Context="entry">
                    @if (!string.IsNullOrEmpty(entry.RecapUrl))
                    {
                        <a href="@entry.RecapUrl">View Gallery</a>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

</div>

@code {
    private bool               _loading = true;
    private string?            _errorMessage;
    private string             _year     = string.Empty;
    private List<LeaderboardEntryDto> _entries = [];

    private static string GetRankClass(int rank) => rank switch
    {
        1 => "rank-gold",
        2 => "rank-silver",
        3 => "rank-bronze",
        _ => string.Empty,
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Api.GetLeaderboardAsync();
            if (result is not null)
            {
                _year    = result.Year;
                _entries = result.Entries;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load leaderboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

}

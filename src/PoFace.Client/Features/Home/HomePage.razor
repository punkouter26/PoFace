@page "/"
@attribute [AllowAnonymous]
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>PoFace Terminal</PageTitle>

<section class="panel home-main-panel" aria-label="PoFace Arcade">
    <p class="home-status-line">
        System Status: <span class="status-active">Active</span>
        &nbsp;&mdash;&nbsp; 5 rounds &middot; one emotion per round &middot; max 50 pts
    </p>

    <div class="home-cta-row">
        <a class="btn btn-outline-success glow home-start-btn" href="/arena">&#9658; Start Game</a>
    </div>

    <p class="home-camera-notice">&#128247; Camera access required in your browser</p>

    @if (_isAuthenticated)
    {
        <p class="home-auth-notice home-auth-ok">&#10003; Signed in as <strong>@_userName</strong> &mdash; scores and recap photos will be saved &mdash; <a href="authentication/logout">logout</a></p>
    }
    else
    {
        <p class="home-auth-notice"><a href="authentication/login">Sign in</a> to save high scores &amp; recap photos</p>
    }

    <details class="how-to-play" aria-label="Game instructions">
        <summary>How To Play &#9654;</summary>
        <ol>
            <li>Press Start Game.</li>
            <li>Match the requested emotion before shutter.</li>
            <li>Keep your face centered and front-facing.</li>
            <li>Complete all 5 rounds for your total score.</li>
            <li>Signed-in runs save high scores and recap galleries; anonymous runs stay local.</li>
        </ol>
    </details>
</section>

@code {
    private bool _isAuthenticated;
    private string _userName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
        if (_isAuthenticated)
        {
            _userName = state.User.Identity?.Name
                ?? state.User.FindFirst("preferred_username")?.Value
                ?? state.User.FindFirst("email")?.Value
                ?? "authenticated-user";
        }
    }
}

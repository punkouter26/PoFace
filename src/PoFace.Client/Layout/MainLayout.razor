@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject PoFace.Client.Services.ThemeService ThemeService

<div class="terminal-shell">
    <header class="terminal-header panel glow">
        <span class="header-brand" aria-label="PoFace logo">PoFace<span class="brand-sep">::</span>Arcade</span>
        <div class="status-line">
            <AuthorizeView>
                <Authorized>
                    <span class="operator-identity">
                        Operator: @(context.User.Identity?.Name ?? context.User.FindFirst("preferred_username")?.Value ?? "authenticated-user")
                        <a href="authentication/logout" class="header-logout-link">[logout]</a>
                    </span>
                </Authorized>
                <NotAuthorized>
                    <span>Operator: anonymous &mdash; <a href="authentication/login" class="header-login-link">sign in</a></span>
                </NotAuthorized>
            </AuthorizeView>
            <span class="status-active">SYSTEM ONLINE</span>
        </div>
        <nav class="terminal-nav" aria-label="Primary">
            <NavLink href="/" Match="NavLinkMatch.All" ActiveClass="nav-active">Home</NavLink>
            <NavLink href="/arena" ActiveClass="nav-active">Arena</NavLink>
            <NavLink href="/leaderboard" ActiveClass="nav-active">Leaderboard</NavLink>
        </nav>
    </header>

    <main>
        <article class="content px-3 px-md-4 py-3">
            @Body
        </article>
    </main>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
    }
}

@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject PoFace.Client.Shared.ThemeService ThemeService

<div class="terminal-shell">
    <header class="terminal-header panel glow">
        <pre class="ascii-logo" aria-label="PoFace logo">POFACE::ARCADE</pre>
        <div class="status-line">
            <AuthorizeView>
                <Authorized>
                    <span>Operator: @(context.User.Identity?.Name ?? "authenticated-user")</span>
                </Authorized>
                <NotAuthorized>
                    <span>Operator: anonymous</span>
                </NotAuthorized>
            </AuthorizeView>
            <span class="status-active">SYSTEM ONLINE</span>
        </div>
        <nav class="terminal-nav" aria-label="Primary">
            <a href="/">Home</a>
            <a href="/arena">Arena</a>
            <a href="/leaderboard">Leaderboard</a>
            <a href="/diag">PoVerify</a>
        </nav>
    </header>

    <main>
        <article class="content px-3 px-md-4 py-3">
            @Body
        </article>
    </main>

    <footer class="terminal-footer panel">
        <a href="/diag">PoVerify Diagnostics</a>
    </footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
    }
}

  UpdateElementStyle(webapp, $fontColor="#fff", $bgColor="#1565c0", $borderColor="#0d47a1")
  UpdateElementStyle(entra, $fontColor="#fff", $bgColor="#1a237e", $borderColor="#0d47a1")
  UpdateElementStyle(vision, $fontColor="#fff", $bgColor="#bf360c", $borderColor="#7f0000")
  UpdateElementStyle(kv, $fontColor="#fff", $bgColor="#6a1b9a", $borderColor="#4a148c")

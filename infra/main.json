    "sharedKeyVaultUri": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('sharedKeyVaultResourceGroupName')), 'Microsoft.KeyVault/vaults', parameters('sharedKeyVaultName')), '2023-07-01').vaultUri]"

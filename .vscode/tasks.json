{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "poface: stop stale api",
      "type": "shell",
      "command": "Get-CimInstance Win32_Process -Filter \"name = 'dotnet.exe'\" | Where-Object { $_.CommandLine -match 'PoFace.Api' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      }
    },
    {
      "label": "poface: build api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/PoFace.Api/PoFace.Api.csproj"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "poface: prepare debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "poface: stop stale api",
        "poface: build api"
      ],
      "problemMatcher": []
    }
  ]
}